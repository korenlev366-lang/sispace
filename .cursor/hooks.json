{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": ".cursor/hooks/before-submit-prompt.sh",
        "matcher": "UserPromptSubmit",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "preToolUse": [
      {
        "command": ".cursor/hooks/pre-tool-use.sh",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "sessionEnd": [
      {
        "command": ".cursor/hooks/post-task-adapter.sh",
        "timeout": 5,
        "failClosed": false
      }
    ]
  }
}