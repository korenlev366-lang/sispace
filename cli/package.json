{
  "name": "cursorsi",
  "version": "0.1.0",
  "description": "CursorSI CLI — terminal-native Cursor agent client (Ink TUI)",
  "type": "module",
  "private": true,
  "bin": {
    "cursorsi": "bin/cursorsi.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node bin/cursorsi.mjs",
    "version:bench": "node -e \"const t=performance.now();require('child_process').execSync('node bin/cursorsi.mjs --version',{cwd:process.cwd()});console.log(Math.round(performance.now()-t)+'ms')\""
  },
  "dependencies": {
    "@openrouter/agent": "^0.7.1",
    "@openrouter/sdk": "^0.12.79",
    "ink": "^5.2.0",
    "openai": "^4.104.0",
    "react": "^18.3.1",
    "tiktoken": "^1.0.22",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.12",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=22.5"
  }
}
